# Copiar a .env en este directorio (core/) antes de arrancar el API:
#   copy env.example .env   (Windows)   |   cp env.example .env   (Unix)
#
# Hugging Face — solo si usás core/services/download_models.py o modelos privados
# HuggingFaceToken=

# --- API ---
# API_HOST=127.0.0.1
# API_PORT=8000
# API_TIMEOUT_S=30

# --- Almacenamiento ---
# CHROMA_PERSIST_DIR=./data/chroma
# CHROMA_COLLECTION=local_rag_chunks
# CHROMA_DISTANCE=cosine
# SQLITE_PATH=./data/rag.db
# S3_DIR=./s3
# FTS_TABLE=chunks_fts
# FTS_TOKENIZER=unicode61

# --- Chunking y embeddings ---
# CHUNKING_TOKENIZER_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
# CHUNKING_MAX_TOKENS=256
# EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DEVICE=cpu

# --- Recuperación y rerank ---
# RAG_CANDIDATE_K=30
# RAG_RERANK_K=10
# RAG_FINAL_K=5
#
# Hybrid retrieval (RRF)
# RAG_SEMANTIC_THRESHOLD=0.0     # 0.0 = sin filtro; recomendado 0.35–0.50 con all-MiniLM-L6-v2
# RAG_RRF_K=60                   # constante de suavizado RRF (60 es el estándar académico)
#
# Cross-encoder reranker
# RERANK_STRATEGY=cross_encoder
# MMR_LAMBDA=0.5                 # 0 = solo diversidad, 1 = solo relevancia
# CROSS_ENCODER_ENABLED=false    # true descarga el modelo en el primer arranque
# CROSS_ENCODER_MODEL_ID=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Generación (llama.cpp) ---
# Ruta al .gguf; si está vacío, se intenta el primer *.gguf en core/models
LLAMACPP_MODEL_PATH=
# LLAMACPP_N_CTX=4096
# LLAMACPP_N_THREADS=4
# LLAMACPP_N_GPU_LAYERS=0
# LLAMACPP_MAX_TOKENS=512
# LLAMACPP_TEMPERATURE=0.2

# --- Observabilidad ---
# LOG_LEVEL=INFO
# LOG_JSON=true
# PROMETHEUS_ENABLED=true
# PII_REDACTION_ENABLED=true
